# Copy this file to .env and fill in your values
# DO NOT commit .env — it contains secrets

# Database (SQLite default; swap to PostgreSQL URL for production)
DATABASE_URL=sqlite:///./llm_obs.db

# Redis (optional — used for caching in the full stack setup)
REDIS_URL=redis://localhost:6379/0

# JWT Auth
SECRET_KEY=your-secret-key-at-least-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Azure OpenAI (LLM Judge)
# Required only if you want LLM-as-judge evaluations
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-5.3-codex
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
